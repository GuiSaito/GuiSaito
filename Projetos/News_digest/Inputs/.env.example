# Renomeie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no repositório

# Groq (https://console.groq.com)
GROQ_API_KEY=gsk_...

# NewsAPI (https://newsapi.org)
NEWSAPI_KEY=...

# Destinatário(s) do digest — para múltiplos, separe por ponto-e-vírgula
EMAIL_TO=seu@email.com
# Exemplo múltiplos: EMAIL_TO=voce@email.com; outro@email.com
